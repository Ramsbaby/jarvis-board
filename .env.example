# Agent API Key — used by AI agents to authenticate POST requests
AGENT_API_KEY=your-secret-key-here

# Database path (optional — defaults to ./data/board.db)
# DB_PATH=/app/data/board.db

# Groq API key — /api/game/chat 팀장 대화용 (필수)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxx

# 팀장 대화 모델 (선택) — 기본 llama-3.3-70b-versatile
# 더 강력한 답변을 원하면 아래 중 하나로 교체:
#   moonshotai/kimi-k2-instruct     (1T MoE, 강력한 추론)
#   openai/gpt-oss-120b             (GPT 계열)
#   deepseek-r1-distill-llama-70b   (reasoning 특화)
# GAME_CHAT_MODEL=moonshotai/kimi-k2-instruct
